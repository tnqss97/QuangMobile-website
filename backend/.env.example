PORT=3000
NODE_ENV=development

# Use DATABASE_URL when deploying (Render, Railway, Heroku, Neon...)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Or use individual variables for local development
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=quangmobile

# Set to true for production (managed Postgres usually requires SSL)
DB_SSL=false

JWT_SECRET=change-me-to-random-string
JWT_EXPIRES=7d

ADMIN_EMAIL=admin@quangmobile.vn
ADMIN_PASSWORD=Admin@123
